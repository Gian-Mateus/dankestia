#!/usr/bin/make -f

export DH_VERBOSE = 1

# Extract version from debian/changelog
DEB_VERSION := $(shell dpkg-parsechangelog -S Version)
# Get upstream version (strip -1ppa1 suffix)
UPSTREAM_VERSION := $(shell echo $(DEB_VERSION) | sed 's/-[^-]*$$//')
BASE_VERSION := $(shell echo $(UPSTREAM_VERSION) | sed 's/ppa[0-9]*$$//' | sed 's/+git.*//')

%:
	dh $@

override_dh_auto_build:
	# All files are included in source package
	test -f dankestia-greeter-source.tar.gz || (echo "ERROR: dankestia-greeter-source.tar.gz not found!" && exit 1)

	# Extract source tarball
	tar -xzf dankestia-greeter-source.tar.gz
	# Find the extracted directory
	SOURCE_DIR=$$(find . -maxdepth 1 -type d -name "Dankestia*" | head -n1); \
	if [ -n "$$SOURCE_DIR" ]; then \
		ln -sf $$SOURCE_DIR Dankestia-$(BASE_VERSION); \
	fi

override_dh_auto_install:
	# Install greeter files to shared data location
	mkdir -p debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter
	cp -r Dankestia-$(BASE_VERSION)/quickshell/* debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/

	# Install launcher script
	install -Dm755 Dankestia-$(BASE_VERSION)/quickshell/Modules/Greetd/assets/dankestia-greeter \
		debian/dankestia-greeter/usr/bin/dankestia-greeter

	# Install documentation
	install -Dm644 Dankestia-$(BASE_VERSION)/quickshell/Modules/Greetd/README.md \
		debian/dankestia-greeter/usr/share/doc/dankestia-greeter/README.md

	# Install LICENSE file
	install -Dm644 Dankestia-$(BASE_VERSION)/LICENSE \
		debian/dankestia-greeter/usr/share/doc/dankestia-greeter/LICENSE

	install -Dpm0644 Dankestia-$(BASE_VERSION)/quickshell/systemd/tmpfiles-dankestia-greeter.conf \
		debian/dankestia-greeter/usr/lib/tmpfiles.d/dankestia-greeter.conf
	install -Dm644 Dankestia-$(BASE_VERSION)/quickshell/systemd/sysusers-dankestia-greeter.conf \
		debian/dankestia-greeter/usr/lib/sysusers.d/dankestia-greeter.conf

	# Create cache directory structure (will be created by postinst)
	mkdir -p debian/dankestia-greeter/var/cache/dankestia-greeter

	# Remove build and development files
	rm -rf debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/core
	rm -rf debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/distro
	rm -rf debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/.git*
	rm -f debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/.gitignore
	rm -rf debian/dankestia-greeter/usr/share/quickshell/dankestia-greeter/.github

override_dh_auto_clean:
	rm -rf Dankestia-*
	dh_auto_clean
