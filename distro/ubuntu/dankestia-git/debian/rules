#!/usr/bin/make -f

export DH_VERBOSE = 1

# Get git commit date for version
GIT_DATE := $(shell date +%Y%m%d)
GIT_COMMIT := HEAD

# Go needs writable directories for its caches
export HOME := $(CURDIR)/debian/tmp-home
export GOCACHE := $(CURDIR)/debian/tmp-home/go-cache
export GOMODCACHE := $(CURDIR)/debian/tmp-home/go-mod

# Launchpad has no network access, so use local toolchain only
export GOTOOLCHAIN := local

%:
	dh $@

override_dh_installsystemd:
	dh_installsystemd --name=dankestia

override_dh_auto_build:
	# Create Go cache directories (sbuild sets HOME to non-existent path)
	mkdir -p $(HOME) $(GOCACHE) $(GOMODCACHE)

	# Git source is already included in source package (cloned by ppa-build.sh)
	# Launchpad build environment has no internet access
	test -d dankestia-git-repo || (echo "ERROR: dankestia-git-repo directory not found!" && exit 1)

	# Patch go.mod for Launchpad: align go directive w/latest Go toolchain
	GO_VERSION=$$(go env GOVERSION | sed -E 's/^go([0-9]+\.[0-9]+).*/\1/'); \
	if [ -n "$$GO_VERSION" ]; then \
		sed -E -i "s/^go 1\.[0-9]+(\.[0-9]+)?/go $$GO_VERSION/" dankestia-git-repo/core/go.mod; \
		if [ -f dankestia-git-repo/core/vendor/modules.txt ]; then \
			sed -E -i "s/^(## explicit; go )1\.[0-9]+(\.[0-9]+)?$$/\1$$GO_VERSION/" dankestia-git-repo/core/vendor/modules.txt; \
		fi; \
	else \
		echo "Warning: Could not detect Go version, leaving go.mod go directive unchanged"; \
	fi
	sed -E -i '/^toolchain go[0-9.]+$$/d' dankestia-git-repo/core/go.mod

	# Build dankestia-cli from source
	# Detect architecture
	$(eval DEB_HOST_ARCH := $(shell dpkg-architecture -qDEB_HOST_ARCH))
	@if [ -f dankestia-git-repo/.dankestia-version ]; then \
		. dankestia-git-repo/.dankestia-version; \
		echo "Building with VERSION=$$VERSION COMMIT=$$COMMIT ARCH=$(DEB_HOST_ARCH)"; \
		cd dankestia-git-repo/core && $(MAKE) GOFLAGS="-mod=vendor" dist ARCH=$(DEB_HOST_ARCH) VERSION="$$VERSION" COMMIT="$$COMMIT"; \
	else \
		echo "Warning: .dankestia-version not found, building without version info"; \
		cd dankestia-git-repo/core && $(MAKE) GOFLAGS="-mod=vendor" dist ARCH=$(DEB_HOST_ARCH); \
	fi
	cp dankestia-git-repo/core/bin/dankestia-linux-$(DEB_HOST_ARCH) dankestia
	chmod +x dankestia

override_dh_auto_install:
	# Install binary
	install -Dm755 dankestia debian/dankestia-git/usr/bin/dankestia

	# Install QML files from git clone
	mkdir -p debian/dankestia-git/usr/share/quickshell/dankestia
	cp -r dankestia-git-repo/* debian/dankestia-git/usr/share/quickshell/dankestia/

	# Remove unnecessary directories
	rm -rf debian/dankestia-git/usr/share/quickshell/dankestia/core
	rm -rf debian/dankestia-git/usr/share/quickshell/dankestia/distro

	# Install systemd user service
	install -Dm644 dankestia-git-repo/assets/systemd/dankestia.service \
		debian/dankestia-git/usr/lib/systemd/user/dankestia.service

	# Install desktop file and icon
	install -Dm644 dankestia-git-repo/assets/dankestia-open.desktop \
		debian/dankestia-git/usr/share/applications/dankestia-open.desktop
	install -Dm644 dankestia-git-repo/assets/danklogo.svg \
		debian/dankestia-git/usr/share/icons/hicolor/scalable/apps/danklogo.svg

	# Create DANKESTIA Version file
	@if [ -f dankestia-git-repo/.dankestia-version ]; then \
		. dankestia-git-repo/.dankestia-version; \
		echo "$$VERSION" > debian/dankestia-git/usr/share/quickshell/dankestia/VERSION; \
	else \
		echo "dev" > debian/dankestia-git/usr/share/quickshell/dankestia/VERSION; \
	fi

override_dh_auto_clean:
	# Don't delete dankestia-git-repo directory - it's part of the source package (native format)
	# Clean up build artifacts
	rm -f dankestia
	rm -rf dankestia-git-repo/core/bin
	rm -rf debian/tmp-home
	dh_auto_clean
